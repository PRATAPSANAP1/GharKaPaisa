# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173,https://gharkapaisa.in

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gharkapaisa
DB_USER=postgres
DB_PASSWORD=your_db_password

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
OTP_PEPPER=change_me_otp_pepper
COOKIE_DOMAIN=

# Super admins are seeded only when SUPER_ADMIN_SEED_PASSWORD is set.
# Format: email:mobile:full_name (comma-separated for multiple admins)
SUPER_ADMIN_SEED_PASSWORD=
SUPER_ADMIN_RESET_PASSWORD=false
SUPER_ADMIN_SEEDS=sharadyohesa@gmail.com:8087179438:Sharad Yohesa,pratapsanap14@gmail.com:9370470692:Pratap Sanap

# ── AWS (S3 + SES) ────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_SES_FROM_EMAIL=noreply@gharkapaisa.in

# ── MSG91 (SMS OTP) ───────────────────────────────────────────────────────────
# Never expose MSG91_AUTH_KEY as EXPO_PUBLIC_* or commit the real value.
MSG91_AUTH_KEY=your_msg91_auth_key

# ── Wallet ────────────────────────────────────────────────────────────────────
COMMISSION_CREDIT_HOLD_HOURS=48

# ── Dev utilities ─────────────────────────────────────────────────────────────
ENABLE_TEST_EMAIL_ROUTE=false

# ── Encryption (partner bank account numbers at rest) ─────────────────────────
ENCRYPTION_KEY=32_byte_hex_key_for_aes_256_gcm
